# Client data — generated by /onboard or daily use. NEVER tracked by the template.
# This is what makes `git pull` safe forever: template updates can't touch client files.
profile/*
!profile/.gitkeep
tasks/*
!tasks/.gitkeep
sessions/*
!sessions/.gitkeep
wiki/pages/*
!wiki/pages/.gitkeep
wiki/index.md

# OS noise
.DS_Store
.obsidian/
